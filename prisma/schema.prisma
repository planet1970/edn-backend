generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int              @id @default(autoincrement())
  email             String           @unique
  password          String?
  name              String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  googleId          String?
  imageUrl          String?
  phone             String?
  visitorId         String?          @unique
  isEdirnelim       Boolean          @default(false)
  username          String?          @unique
  isActive          Boolean          @default(true)
  roleId            String?          @default("USER")
  completedMessages ContactMessage[] @relation("CompletedMessages")
  pageAuthorities   PageAuthority[]
  createdPlaces     Place[]          @relation("CreatedPlaces")
  updatedPlaces     Place[]          @relation("UpdatedPlaces")
  tempFoodPlaces    TempFoodPlace[]  @relation("TempFoodPlaceUpdatedBy")
  tempPlacesCreated TempPlace[]      @relation("TempPlaceCreatedBy")
  tempPlacesUpdated TempPlace[]      @relation("TempPlaceUpdatedBy")
  role              UserType?        @relation(fields: [roleId], references: [id])
  visitor           Visitor?         @relation(fields: [visitorId], references: [fingerprint])
}

model UserType {
  id          String   @id
  title       String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model Category {
  id            Int           @id @default(autoincrement())
  title         String
  description   String?
  iconName      String?
  order         Int           @default(1)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  isActive      Boolean       @default(true)
  webIcon       String?
  pagePlans     PagePlan[]
  places        Place[]
  subCategories SubCategory[]
}

model SubCategory {
  id          Int         @id @default(autoincrement())
  title       String
  description String?
  order       Int         @default(1)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  categoryId  Int
  imageUrl    String?
  pageDesign  String?
  isActive    Boolean     @default(true)
  foodPlaces  FoodPlace[]
  pagePlans   PagePlan[]
  places      Place[]
  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

model Place {
  id               Int          @id @default(autoincrement())
  title            String
  slug             String?
  pic_url          String?
  icon1            String?
  title1           String?
  info1            String?
  icon2            String?
  title2           String?
  info2            String?
  icon3            String?
  title3           String?
  info3            String?
  icon4            String?
  title4           String?
  info4            String?
  description      String?
  rating           Float?
  panel1_title     String?
  panel1           String?
  panel2_title     String?
  panel2           String?
  panel_col_title  String?
  panel_col        String?
  panel3_title     String?
  panel3           String?
  panel4_title     String?
  panel4           String?
  panel_col_title2 String?
  panel_col2       String?
  panel5_title     String?
  area1            String?
  area2            String?
  area3            String?
  area4            String?
  area5            String?
  area6            String?
  area7            String?
  area8            String?
  area9            String?
  area10           String?
  source           String?
  isActive         Boolean      @default(true)
  createdById      Int?
  updatedById      Int?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  order            Int          @default(0)
  back_pic_url     String?
  categoryId       Int?
  subCategoryId    Int?
  category         Category?    @relation(fields: [categoryId], references: [id])
  createdBy        User?        @relation("CreatedPlaces", fields: [createdById], references: [id])
  subCategory      SubCategory? @relation(fields: [subCategoryId], references: [id])
  updatedBy        User?        @relation("UpdatedPlaces", fields: [updatedById], references: [id])
}

model PagePlan {
  id               String      @id @default(uuid())
  categoryId       Int
  subCategoryId    Int
  pageDefinitionId String
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  pageTitle        String?
  slug             String?
  source           String?
  category         Category    @relation(fields: [categoryId], references: [id])
  subCategory      SubCategory @relation(fields: [subCategoryId], references: [id])
}

model PageDefinition {
  id          String   @id @default(uuid())
  title       String
  description String?
  isActive    Boolean  @default(true)
  dbId        String
  fields      Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PageLink {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  slug        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  targetTable String   @default("PLACE")
}

model FoodPlace {
  id            Int         @id @default(autoincrement())
  title         String
  subtitle      String?
  mainColor     String?
  imageUrl      String?
  backImageUrl  String?
  campaignUrl   String?
  badge         String?
  rating        Float?
  storyTitle    String?
  phone         String?
  hoursMon      String?
  hoursTue      String?
  hoursWed      String?
  hoursThu      String?
  hoursFri      String?
  hoursSat      String?
  hoursSun      String?
  menuItem1     String?
  menuDesc1     String?
  menuPrice1    String?
  menuItem2     String?
  menuDesc2     String?
  menuPrice2    String?
  menuItem3     String?
  menuDesc3     String?
  menuPrice3    String?
  menuItem4     String?
  menuDesc4     String?
  menuPrice4    String?
  menuItem5     String?
  menuDesc5     String?
  menuPrice5    String?
  menuItem6     String?
  menuDesc6     String?
  menuPrice6    String?
  menuItem7     String?
  menuDesc7     String?
  menuPrice7    String?
  menuItem8     String?
  menuDesc8     String?
  menuPrice8    String?
  menuItem9     String?
  menuDesc9     String?
  menuPrice9    String?
  menuItem10    String?
  menuDesc10    String?
  menuPrice10   String?
  features      String?
  address       String?
  website       String?
  field1        String?
  field2        String?
  field3        String?
  field4        String?
  field5        String?
  isActive      Boolean     @default(true)
  subCategoryId Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  slug          String?
  hoursEveryday String?
  backContent   String?
  description   String?
  frontContent  String?
  order         Int         @default(0)
  subCategory   SubCategory @relation(fields: [subCategoryId], references: [id])
}

model SplashScreen {
  id              Int      @id @default(autoincrement())
  backgroundColor String?
  logoUrl         String?
  duration        Int      @default(3000)
  tagline         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model OnboardingScreen {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  imageUrl    String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  icon        String?  @default("map")
}

model WebHeroSlide {
  id               String   @id @default(uuid())
  title            String?
  subtitle         String?
  description      String?
  imageUrl         String?
  order            Int      @default(0)
  createdAt        DateTime @default(now())
  titleColor       String?  @default("#FFB627")
  subtitleColor    String?  @default("#FFFFFF")
  descriptionColor String?  @default("#FFFFFF")
  titleShadowColor String?  @default("rgba(0,0,0,0.9)")
  updatedAt        DateTime @updatedAt
}

model WebSocialInfo {
  id           Int      @id @default(autoincrement())
  phone        String?
  email        String?
  address      String?
  facebook     String?
  instagram    String?
  twitter      String?
  youtube      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  workingHours String?
}

model WebNavbar {
  id         Int      @id @default(autoincrement())
  logoUrl    String?
  title      String?
  titleColor String?  @default("#333333")
  fontFamily String?  @default("Inter")
  fontSize   Int?     @default(24)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  bgColor    String?  @default("#1A1A2E")
  iconColor  String?  @default("#FFB627")
}

model Visitor {
  id            String   @id @default(uuid())
  fingerprint   String   @unique
  lastIp        String?
  userAgent     String?
  lastVisitAt   DateTime @default(now())
  visitCount    Int      @default(0)
  customMessage String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  username      String?  @unique
  User          User?
}

model StoryAdvertisement {
  id         Int      @id @default(autoincrement())
  title      String
  imageUrl   String?
  link       String?  @default("#")
  isNew      Boolean  @default(true)
  order      Int      @default(0)
  isActive   Boolean  @default(true)
  sourceType String?
  sourceId   Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model FeaturedAdvertisement {
  id           Int      @id @default(autoincrement())
  title        String
  category     String?
  imageUrl     String?
  discount     String?
  description  String?
  rating       Float?   @default(0)
  link         String?  @default("#")
  order        Int      @default(0)
  isActive     Boolean  @default(true)
  sourceType   String?
  sourceId     Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  mainCategory String?
  slogan       String?
}

model WebGoogleAd {
  id         Int      @id @default(autoincrement())
  areaName   String   @unique
  type       String   @default("SCRIPT")
  scriptCode String?
  imageUrl   String?
  linkUrl    String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model WebPopupAd {
  id              Int       @id @default(autoincrement())
  imageUrl        String
  linkUrl         String?
  isActive        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  title           String?
  viewCount       Int       @default(0)
  displayStrategy String    @default("ALWAYS")
  endDate         DateTime?
  startDate       DateTime?
  isDefault       Boolean   @default(false)
}

model WebDefaultPopup {
  id              Int      @id @default(autoincrement())
  title           String?
  imageUrl        String
  linkUrl         String?
  isActive        Boolean  @default(false)
  displayStrategy String   @default("ONCE_PER_HOUR")
  updatedAt       DateTime @updatedAt
}

model PopularPlaceAdvertisement {
  id           Int      @id @default(autoincrement())
  title        String
  description  String?
  imageUrl     String?
  rating       Float?   @default(0)
  visitCount   Int?     @default(0)
  link         String?  @default("#")
  badge        String?
  hours        String?
  location     String?
  order        Int      @default(0)
  isActive     Boolean  @default(true)
  sourceType   String?
  sourceId     Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  icon1        String?
  icon2        String?
  info1        String?
  info2        String?
  category     String?
  mainCategory String?
  slogan       String?
}

model WebAboutSection {
  id          Int            @id @default(autoincrement())
  title       String?
  description String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  cards       WebAboutCard[]
}

model WebAboutCard {
  id        Int             @id @default(autoincrement())
  icon      String?
  title     String?
  summary   String?
  content   String?
  order     Int             @default(0)
  isActive  Boolean         @default(true)
  sectionId Int
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  section   WebAboutSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
}

model ContactMessage {
  id            Int      @id @default(autoincrement())
  name          String
  email         String
  subject       String?
  message       String
  status        String   @default("Bekliyor")
  completedById Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  completedBy   User?    @relation("CompletedMessages", fields: [completedById], references: [id])
}

model PageAuthority {
  id         Int      @id @default(autoincrement())
  userId     Int
  sourceType String
  sourceId   Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sourceType, sourceId])
}

model TempPlace {
  id               Int      @id @default(autoincrement())
  originalId       Int?
  title            String
  pic_url          String?
  back_pic_url     String?
  icon1            String?
  title1           String?
  info1            String?
  icon2            String?
  title2           String?
  info2            String?
  icon3            String?
  title3           String?
  info3            String?
  icon4            String?
  title4           String?
  info4            String?
  description      String?
  rating           Float?
  panel1_title     String?
  panel1           String?
  panel2_title     String?
  panel2           String?
  panel_col_title  String?
  panel_col        String?
  panel3_title     String?
  panel3           String?
  panel4_title     String?
  panel4           String?
  panel_col_title2 String?
  panel_col2       String?
  panel5_title     String?
  area1            String?
  area2            String?
  area3            String?
  area4            String?
  area5            String?
  area6            String?
  area7            String?
  area8            String?
  area9            String?
  area10           String?
  source           String?
  order            Int      @default(0)
  categoryId       Int?
  subCategoryId    Int?
  updatedById      Int?
  status           String   @default("PENDING")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  createdById      Int?
  isActive         Boolean  @default(true)
  slug             String?
  createdBy        User?    @relation("TempPlaceCreatedBy", fields: [createdById], references: [id])
  updatedBy        User?    @relation("TempPlaceUpdatedBy", fields: [updatedById], references: [id])
}

model TempFoodPlace {
  id            Int      @id @default(autoincrement())
  originalId    Int?
  title         String
  subtitle      String?
  mainColor     String?
  imageUrl      String?
  backImageUrl  String?
  campaignUrl   String?
  badge         String?
  rating        Float?
  storyTitle    String?
  description   String?
  backContent   String?
  phone         String?
  hoursEveryday String?
  hoursMon      String?
  hoursTue      String?
  hoursWed      String?
  hoursThu      String?
  hoursFri      String?
  hoursSat      String?
  hoursSun      String?
  menuItem1     String?
  menuDesc1     String?
  menuPrice1    String?
  menuItem2     String?
  menuDesc2     String?
  menuPrice2    String?
  menuItem3     String?
  menuDesc3     String?
  menuPrice3    String?
