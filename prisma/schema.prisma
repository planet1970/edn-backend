  field3        String?
  field4        String?
  field5        String?
  subCategoryId Int
  updatedById   Int?
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  isActive      Boolean  @default(true)
  slug          String?
  frontContent  String?
  updatedBy     User?    @relation("TempFoodPlaceUpdatedBy", fields: [updatedById], references: [id])
}

model WebSetting {
  id           String   @id @default("GLOBAL")
  isNewsActive Boolean  @default(true)
  updatedAt    DateTime @updatedAt
}

model WebNewsItem {
  id             Int       @id @default(autoincrement())
  title          String
  link           String    @unique
  pubDate        DateTime?
  source         String?
  contentSnippet String?
  isActive       Boolean   @default(true)
  isManual       Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model DailyVisitStats {
  id          Int      @id @default(autoincrement())
  date        DateTime @unique
  webCount    Int      @default(0)
  mobileCount Int      @default(0)
  totalCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  uniqueCount Int      @default(0)
  searchCount Int      @default(0)
}
